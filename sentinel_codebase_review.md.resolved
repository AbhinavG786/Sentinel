## 6. Database Schema

```mermaid
erDiagram
    users ||--o{ incidents : "reported_by / assigned_to"
    users ||--o{ team_members : "member"
    teams ||--o{ team_members : "has"
    teams ||--o{ incidents : "team_id"
    incidents ||--o{ alerts : "incident_id"
    incidents ||--o{ policy_logs : "incident_id"
    knowledge_policies ||--o{ policy_logs : "policy_id"
    users ||--o{ audit_logs : "user_id"
    users ||--o{ knowledge_policies : "created_by"

    users {
        UUID id PK
        VARCHAR name
        VARCHAR email UK
        VARCHAR password_hash
        VARCHAR role
    }
    teams {
        UUID id PK
        VARCHAR name UK
        TEXT description
    }
    team_members {
        UUID id PK
        UUID team_id FK
        UUID user_id FK
        VARCHAR role_in_team
    }
    incidents {
        UUID id PK
        UUID temp_id UK
        UUID trace_id
        VARCHAR source
        TEXT sanitized_snippet
        VARCHAR title
        TEXT description
        VARCHAR severity
        VARCHAR status
        JSONB ai_summary
    }
    knowledge_policies {
        UUID id PK
        VARCHAR name
        TEXT_ARRAY blocked_keywords
        TEXT_ARRAY allowed_domains
        UUID created_by FK
    }
    policy_logs {
        UUID id PK
        UUID incident_id FK
        UUID policy_id FK
        TEXT detected_violation
        VARCHAR action_taken
    }
    audit_logs {
        UUID id PK
        UUID user_id FK
        VARCHAR entity_type
        UUID entity_id
        VARCHAR action
        JSONB details
    }
    alerts {
        UUID id PK
        UUID incident_id FK
        TEXT message
        VARCHAR severity
        BOOLEAN acknowledged
    }
    system_events {
        UUID id PK
        VARCHAR event_type
        VARCHAR source
        JSONB payload
        BOOLEAN processed
    }
```


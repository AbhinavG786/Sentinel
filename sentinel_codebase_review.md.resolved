## 5. Database Schema Summary

```mermaid
erDiagram
    users {
        UUID id PK
        VARCHAR name
        VARCHAR email UK
        VARCHAR password_hash
        VARCHAR role
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    teams {
        UUID id PK
        VARCHAR name UK
        TEXT description
        TIMESTAMPTZ created_at
    }

    team_members {
        UUID id PK
        UUID team_id FK
        UUID user_id FK
        VARCHAR role_in_team
        TIMESTAMPTZ joined_at
    }

    incidents {
        UUID id PK
        UUID temp_id UK
        UUID trace_id
        VARCHAR source
        TEXT sanitized_snippet
        VARCHAR title
        TEXT description
        VARCHAR severity
        VARCHAR status
        UUID reported_by FK
        UUID assigned_to FK
        UUID team_id FK
        JSONB ai_summary
        TIMESTAMPTZ created_at
        TIMESTAMPTZ updated_at
    }

    knowledge_policies {
        UUID id PK
        VARCHAR name
        TEXT description
        TEXT_ARRAY blocked_keywords
        TEXT_ARRAY allowed_domains
        UUID created_by FK
        TIMESTAMPTZ created_at
    }

    policy_logs {
        UUID id PK
        UUID user_id FK
        UUID incident_id FK
        UUID policy_id FK
        TEXT detected_violation
        TEXT ai_response_snippet
        VARCHAR action_taken
        TIMESTAMPTZ created_at
    }

    system_events {
        UUID id PK
        VARCHAR event_type
        VARCHAR source
        JSONB payload
        BOOLEAN processed
        TIMESTAMPTZ created_at
    }

    audit_logs {
        UUID id PK
        UUID user_id FK
        VARCHAR entity_type
        UUID entity_id
        VARCHAR action
        JSONB details
        TIMESTAMPTZ created_at
    }

    alerts {
        UUID id PK
        UUID incident_id FK
        UUID triggered_by FK
        TEXT message
        VARCHAR severity
        BOOLEAN acknowledged
        TIMESTAMPTZ created_at
    }

    users ||--o{ team_members : "member"
    teams ||--o{ team_members : "has"
    users ||--o{ incidents : "reported_by"
    users ||--o{ incidents : "assigned_to"
    teams ||--o{ incidents : "team_id"
    incidents ||--o{ policy_logs : "incident_id"
    knowledge_policies ||--o{ policy_logs : "policy_id"
    incidents ||--o{ alerts : "incident_id"
    users ||--o{ audit_logs : "user_id"
    users ||--o{ knowledge_policies : "created_by"
```

